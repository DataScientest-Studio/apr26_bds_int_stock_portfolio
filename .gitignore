# --- clone-and-show: sealed results + demo/daily bars ship COMMITTED ---
#   xgb/data/oos_metrics.db  xgb/data/bars_demo.duckdb  xgb/data/per_asset_feature_overrides.json
#   xgb/plan/data/dashboard.json  lstm/oos_metrics.db  lstm/data/sp500_1d.duckdb
#   lstm/per_asset_feature_overrides.json  lstm/dashboard/data/dashboard.json
# so a fresh clone renders the app + both dashboards instantly (each subproject keeps its own .gitignore).

# One shared virtualenv at the repo root; the per-subproject .venv are symlinks to it (make deps).
.venv/
xgb/.venv
lstm/.venv

# The FULL XGB 1h bars (160 MB) stay LOCAL; the committed mini bars_demo.duckdb cover demo verify.
xgb/data/liora.duckdb

# Per-asset run scratch (regenerable; the sealed rows ship committed).
xgb/Assets/*/
lstm/Assets/*/
lstm/cache/
xgb/data/verify_scratch.db*
lstm/data/verify_scratch.db*
# SQLite WAL/SHM side-files of the committed results stores.
*.db-wal
*.db-shm

# Python / OS / IDE
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.DS_Store
.vscode/
.idea/

# Background/scratch runtime (regenerable).
*.pid
*.log
logs/
search_state.db*
search_control.json
.overrides.lock

# --- WO-FS study (fs/artifacts) ---
# Commit the SMALL demo artifacts so a fresh clone renders the study pages instantly:
#   fs/artifacts/demo/*.json  fs/artifacts/demo/optuna.db  fs/artifacts/demo/fs_results.duckdb
# Ignore the regenerable feature cache, per-fold scalers, DB side-files, and the FULL universe run.
fs/artifacts/cache/
fs/artifacts/pcache/
fs/artifacts/**/scalers/
fs/artifacts/full/
*.duckdb.tmp
fs/artifacts/**/*.parquet.tmp
fs/artifacts/**/supervisor_progress.json
fs/artifacts/**/supervisor_DONE.flag
fs/features_proposed.lock

# --- parent project's data plane (fetch_data.py outputs; regenerable) ---
data/*.csv
data/by_ticker/
# Report PDFs (regenerate locally via reports/build_pdf.sh)
reports/*.pdf
# ...but keep the versioned milestone deliverables under version control
!reports/report_v*.pdf
# Secrets
.env.local
.env
# Internal working drafts — never a deliverable, must never be committed
reports/_internal_drafts/
