// scale factor for screen-space glyphs → keep them inside a level's dashed boundaries (no overflow into neighbours)
function bandFit(lev){
  var top=(BNDY[lev]!=null)?BNDY[lev]:CAM.S(bp(lev,0.5,0.5)).y,
      bot=(BNDY[lev-1]!=null)?BNDY[lev-1]:CAM.S(bp(lev-1,0.5,0.5)).y;
  return clamp((bot-top)/160,0.32,1.3);
}
