function drawStatusIcon(x,y,col,status){
  ctx.save();ctx.strokeStyle=col;ctx.lineWidth=1.4;ctx.lineCap='round';ctx.setLineDash([]);
  ctx.beginPath();
  if(status==='OK'){ctx.moveTo(x-4,y);ctx.lineTo(x-1,y+3);ctx.lineTo(x+5,y-4);}
  else if(status==='WARN'){ctx.moveTo(x,y-5);ctx.lineTo(x,y+2);ctx.moveTo(x,y+5);ctx.lineTo(x,y+5.2);}
  else{ctx.moveTo(x-4,y-4);ctx.lineTo(x+4,y+4);ctx.moveTo(x+4,y-4);ctx.lineTo(x-4,y+4);}
  ctx.stroke();ctx.restore();
}
function drawFamilyMarker(x,y,fam,col){
  ctx.save();ctx.strokeStyle=col;ctx.fillStyle=rgba(col,0.18);ctx.lineWidth=1.15;ctx.setLineDash([]);
  if(fam==='price_action'){
    ctx.beginPath();ctx.moveTo(x-3,y+4);ctx.lineTo(x-3,y-4);ctx.moveTo(x+3,y+5);ctx.lineTo(x+3,y-5);ctx.stroke();
    ctx.fillRect(x-5,y-1,4,5);ctx.fillRect(x+1,y-4,4,6);
  }else if(fam==='volume'){
    ctx.fillRect(x-5,y+1,3,5);ctx.fillRect(x-1,y-3,3,9);ctx.fillRect(x+3,y-6,3,12);
  }else{
    ctx.beginPath();ctx.moveTo(x-6,y+4);ctx.lineTo(x-1,y-2);ctx.lineTo(x+2,y+0);ctx.lineTo(x+6,y-6);ctx.stroke();
  }
  ctx.restore();
}
function drawMicroSheet(x,y,w,h,col){
  drawFold(x,y,w,h,Math.min(6,w*0.26),col,0.10);
  ctx.save();ctx.strokeStyle=rgba(col,0.7);ctx.lineWidth=1;ctx.setLineDash([]);
  ctx.beginPath();ctx.moveTo(x+4,y+h*0.45);ctx.lineTo(x+w-5,y+h*0.45);
  ctx.moveTo(x+4,y+h*0.66);ctx.lineTo(x+w-7,y+h*0.66);ctx.stroke();ctx.restore();
}
function drawZipCrate(g){
  // 3D "ZIP file" icon: a store-teal layered stack (WinRAR-like) + central clasp + "ZIP" label
  var H=g.h||24,a0=g.a-0.023,b0=g.b-0.046,a1=g.a+0.023,b1=g.b+0.046;
  var SH=g.sel?['#1FB985','#34D89E','#5FE8B8']:['#157A5A','#1D9E75','#3FCB99'];  // bottom→top teal shades
  prism(g.lev,a0,b0,a1,b1,1,H/3,SH[0],0.24);
  prism(g.lev,a0,b0,a1,b1,1+H/3,H/3,SH[1],0.24);
  var top=prism(g.lev,a0,b0,a1,b1,1+2*H/3,H/3,SH[2],g.sel?0.40:0.30);
  var c=ctr(top),detail=(CAM.z>=0.78),acc=g.sel?GREEN:'#0E6A4D';
  if(detail){
    ctx.save();ctx.strokeStyle=rgba(acc,0.6);ctx.lineWidth=1.5;ctx.setLineDash([]);
    ctx.beginPath();ctx.moveTo(c.x,c.y-13);ctx.lineTo(c.x,c.y+12);ctx.stroke();ctx.restore();   // binding seam
    zigzagS(c.x,c.y-13,c.x,c.y-7,3,1.3,rgba(acc,0.75));zigzagS(c.x,c.y+8,c.x,c.y+13,3,1.3,rgba(acc,0.75)); // zip teeth
    fillRR(c.x-12,c.y-7,24,15,3,rgba(acc,0.92),rgba('#0A4A36',0.9),1.1);        // green clasp plate
  }
  txtS('ZIP',c.x,c.y+(detail?4:3),detail?'#FFFFFF':(g.sel?GREEN:vget('--color-text-primary','#eee')),'center',8,'700');
  HITS.addPts([lp(g.lev,g.a-0.030,g.b-0.060,H+4),lp(g.lev,g.a+0.030,g.b+0.060,0)],g.all?{type:'zipall'}:{type:'zip',a:g.i});
  addObstaclePts(top,4);
  return c;
}
