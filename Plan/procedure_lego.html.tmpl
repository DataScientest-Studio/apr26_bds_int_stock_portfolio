        </tbody></table>`+
        svgV(32,[5,10,16,22,18,12,8,4].map((h,i)=>
          `<rect x="${4+i*19}" y="${28-h}" width="17" height="${h}" fill="${i<3?'rgba(242,107,106,.5)':'rgba(52,201,106,.55)'}"/>`).join('')+
          `<line x1="60" y1="2" x2="60" y2="30" stroke="#89929D" stroke-width="1" stroke-dasharray="3 3"/>
           <text x="63" y="8" font-size="5.5" fill="#89929D">PF=1</text>`)+
        `<div class="viz-label">oos_metrics.db → dashboard.json · read-only</div>`},

      /* L9 — folder deliverable: dokładnie 7 plików per asset */
      folder:{h:122,render:()=>svgV(54,`
        <path d="M10,10 v-4 a2,2 0 0 1 2,-2 h34 l6,6" fill="rgba(52,201,106,.10)" stroke="${PAL.good}" stroke-width="1.1"/>
