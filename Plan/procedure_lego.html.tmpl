          const x=18+i*19;
          return `<path d="M${x},16 h10 l5,5 v21 h-15 z" fill="${c}22" stroke="${c}" stroke-width="1"/><path d="M${x+10},16 v5 h5" fill="none" stroke="${c}" stroke-width="1"/>`;
        }).join('')}`)+
        `<div class="f-legend"><span style="color:${PAL.pink}">.ipynb</span><span style="color:${PAL.amber}">.parquet ×3</span><span style="color:${PAL.green}">.json</span><span style="color:${PAL.good}">.py</span><span style="color:${PAL.blue}">.md</span></div>
        <div class="viz-label">Assets/&lt;TICKER&gt;/ · 7 files</div>`}
    };
    function vizCard(m){const v=VIZ[m.viz];return v?v.render(m):'';}

    /* ==================================================================
       [J3] LAYOUT — drabinka dół→góra z persystowanego ORDER (jedyne
       źródło pozycji), tor (x) = grupa; wymiary canvas POCHODNE.
       ================================================================== */
    const BLOCK_W=184, LANE_W=230, GAP=36, MARGIN_X=23, TOP_PAD=70, BOTTOM_PAD=50;
    const LANE_X={};GROUPS.forEach((g,i)=>LANE_X[g.id]=MARGIN_X+i*LANE_W);
    const DIVX=GROUPS.slice(0,-1).map((g,i)=>Math.round((MARGIN_X+i*LANE_W+BLOCK_W+MARGIN_X+(i+1)*LANE_W)/2));
    const CANVAS_W=MARGIN_X*2+(GROUPS.length-1)*LANE_W+BLOCK_W;
    let CANVAS_H=TOP_PAD+BOTTOM_PAD+MODULES.reduce((a,m)=>a+VIZ[m.viz].h+GAP,0)-GAP; /* mutowalne: recomputeCanvasH() po add/delete custom */
    function layoutFor(order){const pos={};let y=CANVAS_H-BOTTOM_PAD;
      order.forEach(id=>{const m=mod(id);if(!m)return;y-=VIZ[m.viz].h;pos[id]={x:LANE_X[m.group],y};y-=GAP;});return pos;}

    /* ==================================================================
       [J4] STATE — localStorage v2: order / custom
       (positions/edges/disabled porzucone)
       ================================================================== */
    const STORAGE='liora-ml-engineering-procedure-lego/v1';
    const $=q=>document.querySelector(q);
    let selectedId=null, inventoryFilter='all', draggedId=null;

    function safe(s){return String(s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]));}
    function group(id){return GROUPS.find(g=>g.id===id)}
    function mod(id){return MODULES.find(m=>m.id===id)}
    function blockH(id){const m=mod(id);return m?VIZ[m.viz].h:54}
    /* order: nieznane id odfiltrowane, duplikaty usunięte, brakujące
       dopisane na końcu (= szczyt drabinki) w kolejności MODULES */
    function sanitizeOrder(order){const ids=new Set(MODULES.map(m=>m.id));
      const out=(Array.isArray(order)?order:[]).filter((id,i,a)=>ids.has(id)&&a.indexOf(id)===i);
      MODULES.forEach(m=>{if(!out.includes(m.id))out.push(m.id);});return out;}
    let _state=null;
    function loadState(){
      try{const raw=JSON.parse(localStorage.getItem(STORAGE));
        if(raw)return {order:sanitizeOrder(raw.order),custom:MODULES.filter(m=>m._custom)};}catch(e){}
      return {order:MODULES.map(m=>m.id),custom:MODULES.filter(m=>m._custom)};}
    function getState(){return _state||(_state=loadState());}
    function saveState(s){_state=s;localStorage.setItem(STORAGE,JSON.stringify(s));}
    function color(m){return group(m.group).color}

    /* ==================================================================
       [J5] ORDER + DND — statyczne zależności z MODULES[].depends +
       insert-with-shift: drop liczy indeks wstawienia z Y drabinki,
       klocki powyżej przesuwają się same (repositionBlocks)
       ================================================================== */
    let zoom=1,panX=0,panY=0,panning=null,panMoved=false;

    function depsOf(id){const m=mod(id);return m&&m.depends?m.depends.slice():[];}
    function dependentsOf(id){return MODULES.filter(m=>(m.depends||[]).includes(id)).map(m=>m.id);}
    function canvasPoint(ev){const r=$('#flowCanvas').getBoundingClientRect();return {x:(ev.clientX-r.left)/zoom,y:(ev.clientY-r.top)/zoom};}

    /* indeks wstawienia k∈[0,n]: liczba klocków, których środek leży PONIŻEJ kursora (drabinka rośnie dół→góra) */
    function insertIndexAt(cy,order,pos){return order.filter(id=>pos[id].y+blockH(id)/2>cy).length;}
    function gapY(k,order,pos){
      if(!order.length)return CANVAS_H-BOTTOM_PAD;
      if(k===0){const id=order[0];return pos[id].y+blockH(id)+GAP/2;}
      return pos[order[k-1]].y-GAP/2;}

    let lastGapK=-1;
    function showInsertLine(k,order,pos){if(k===lastGapK)return;lastGapK=k;const el=$('#insertLine');
      el.hidden=false;el.style.left=MARGIN_X+'px';el.style.width=(CANVAS_W-2*MARGIN_X)+'px';
      el.style.height=Math.max(2,2/zoom)+'px';el.style.top=(gapY(k,order,pos)-1)+'px';}
    function hideInsertLine(){lastGapK=-1;const el=$('#insertLine');if(el)el.hidden=true;}

    /* ==================================================================
       [J6] CANVAS — klocki, sticky nagłówki torów, pan / zoom / drag&drop
       ================================================================== */
    function applyTransform(){const c=$('#flowCanvas');if(c)c.style.transform=`translate(${panX}px,${panY}px) scale(${zoom})`;const v=$('#flowViewport');if(v){const s=20*zoom;v.style.backgroundSize=s+'px '+s+'px';v.style.backgroundPosition=panX+'px '+panY+'px';}syncLaneHeads();}
    function contentBox(){const pos=layoutFor(getState().order);let x0=1e9,y0=1e9,x1=-1e9,y1=-1e9;
      MODULES.forEach(m=>{const p=pos[m.id];x0=Math.min(x0,p.x);y0=Math.min(y0,p.y);x1=Math.max(x1,p.x+BLOCK_W);y1=Math.max(y1,p.y+blockH(m.id));});
      return {x:x0-40,y:y0-70,w:x1-x0+80,h:y1-y0+120};}
    function fitView(){const vp=$('#flowViewport');if(!vp)return;const vw=vp.clientWidth||1000,vh=vp.clientHeight||700;const b=contentBox();
      zoom=Math.max(0.15,Math.min((vw-24)/b.w,(vh-24)/b.h,1.15));panX=Math.round((vw-b.w*zoom)/2-b.x*zoom);panY=Math.round((vh-b.h*zoom)/2-b.y*zoom);applyTransform();}

    function lego(m,p,s){
      const g=group(m.group);
      const el=document.createElement('article');
      el.className=`lego ${selectedId===m.id?'selected':''}`;
      el.dataset.id=m.id;el.draggable=true;
      el.style.setProperty('--accent',g.color);el.style.left=p.x+'px';el.style.top=p.y+'px';el.style.height=blockH(m.id)+'px';
      el.innerHTML=`<div class="studs"><i class="stud"></i><i class="stud"></i><i class="stud"></i><i class="stud"></i></div>`+
        `<div class="lego-top"><span class="lego-id">${m.id}</span><span class="lego-title">${safe(m.title)}</span></div>${vizCard(m)}`;
      el.addEventListener('click',e=>{e.stopPropagation();select(m.id)});
      el.addEventListener('dragstart',e=>{draggedId=m.id;e.dataTransfer.setData('text/plain',m.id);e.dataTransfer.effectAllowed='move';setTimeout(()=>el.style.opacity='.25',0)});
      el.addEventListener('dragend',()=>{el.style.opacity='';draggedId=null;$('#flowCanvas').classList.remove('drag-over');hideInsertLine();});
      return el;
    }
    /* sticky nagłówki torów: warstwa w viewport (poza transformacją),
       pozycja x synchronizowana z pan/zoom w applyTransform */
    function renderLaneHeads(){const c=$('#laneHeads');if(!c)return;
      c.innerHTML=GROUPS.map(g=>`<div class="lane-head" data-group="${g.id}" style="color:${g.color}">${safe(g.name)}</div>`).join('');syncLaneHeads();}
    function syncLaneHeads(){const c=$('#laneHeads');if(!c)return;
      c.querySelectorAll('.lane-head').forEach(el=>{
        el.style.left=(panX+zoom*LANE_X[el.dataset.group])+'px';
        el.style.width=Math.max(24,zoom*BLOCK_W)+'px';});
      const sw=Math.max(1,1/zoom)+'px';
      document.querySelectorAll('#flowCanvas .lane-sep').forEach(d=>d.style.width=sw);}
    function renderLaneSeps(){const c=$('#flowCanvas');
      DIVX.forEach(x=>{const d=document.createElement('div');d.className='lane-sep';d.style.left=x+'px';c.appendChild(d);});}
    function renderCanvas(){
      const canvas=$('#flowCanvas'); canvas.querySelectorAll('.lego').forEach(n=>n.remove());
      const s=getState(),pos=layoutFor(s.order);
      s.order.forEach(id=>{const m=mod(id);if(m)canvas.appendChild(lego(m,pos[id],s));});
    }
    function repositionBlocks(){const s=getState(),pos=layoutFor(s.order);
      document.querySelectorAll('#flowCanvas .lego').forEach(el=>{const p=pos[el.dataset.id];if(p){el.style.left=p.x+'px';el.style.top=p.y+'px';}});}
    function select(id){selectedId=id;renderInventory();renderCanvas();renderInspector(mod(id));}
    function clearSelect(){selectedId=null;renderInventory();renderCanvas();renderInspector(null);}

    $('#flowCanvas').addEventListener('dragover',e=>{
      if(!draggedId)return;                       // obce dragi (pliki itp.) — ignoruj
      e.preventDefault();e.dataTransfer.dropEffect='move';
      $('#flowCanvas').classList.add('drag-over');
      const s=getState(),pos=layoutFor(s.order);
      showInsertLine(insertIndexAt(canvasPoint(e).y,s.order,pos),s.order,pos);});
    $('#flowCanvas').addEventListener('dragleave',e=>{
      if(e.target===$('#flowCanvas')){$('#flowCanvas').classList.remove('drag-over');hideInsertLine();}});
    $('#flowCanvas').addEventListener('drop',e=>{
      e.preventDefault();$('#flowCanvas').classList.remove('drag-over');hideInsertLine();
      const id=e.dataTransfer.getData('text/plain')||draggedId;if(!id||!mod(id))return;
      const s=getState();const k=insertIndexAt(canvasPoint(e).y,s.order,layoutFor(s.order));
      const old=s.order.indexOf(id);
      if(old>=0&&(k===old||k===old+1)){select(id);return;}       // sąsiedni gap = no-op, BEZ modala (instant select)
      const newOrder=s.order.slice();let kk=k;                   // przechwyć proponowany order (modal blokuje → bez liczenia ponownie)
      if(old>=0){newOrder.splice(old,1);if(kk>old)kk--;}         // korekta indeksu po usunięciu
      newOrder.splice(kk,0,id);
      openMoveModal({id,newOrder,summaryHTML:describeMove(id,newOrder)}); // NIE commit — czekaj na OK
    });
    $('#flowCanvas').addEventListener('click',e=>{if(e.target===$('#flowCanvas')){if(panMoved){panMoved=false;return;}clearSelect();}});
    $('#flowViewport').addEventListener('wheel',e=>{e.preventDefault();const vp=$('#flowViewport').getBoundingClientRect();const mx=e.clientX-vp.left,my=e.clientY-vp.top;const f=e.deltaY<0?1.12:1/1.12;const nz=Math.max(0.15,Math.min(3,zoom*f));const cx=(mx-panX)/zoom,cy=(my-panY)/zoom;panX=mx-cx*nz;panY=my-cy*nz;zoom=nz;applyTransform();},{passive:false});
    $('#flowCanvas').addEventListener('pointerdown',e=>{if(e.button!==0)return;if(e.target!==$('#flowCanvas'))return;panning={sx:e.clientX,sy:e.clientY,px:panX,py:panY};panMoved=false;$('#flowCanvas').classList.add('panning');});
    $('#flowCanvas').addEventListener('dblclick',e=>{if(e.target===$('#flowCanvas'))fitView();});
    document.addEventListener('pointermove',e=>{if(!panning)return;panX=panning.px+(e.clientX-panning.sx);panY=panning.py+(e.clientY-panning.sy);if(Math.abs(e.clientX-panning.sx)+Math.abs(e.clientY-panning.sy)>3)panMoved=true;applyTransform();});
    document.addEventListener('pointerup',()=>{if(panning){panning=null;$('#flowCanvas').classList.remove('panning');}});

    /* ==================================================================
       [J7] INVENTORY + INSPECTOR — panele boczne, prompt replikacyjny
       ================================================================== */
    function renderFilters(){
      const opts=[['all','ALL'],...GROUPS.map(g=>[g.id,g.name])];
      $('#filters').innerHTML=opts.map(([id,label])=>`<button class="filter ${inventoryFilter===id?'active':''}" data-filter="${id}">${label}</button>`).join('');
      document.querySelectorAll('.filter').forEach(b=>b.onclick=()=>{inventoryFilter=b.dataset.filter;renderFilters();renderInventory();});
    }
    function renderInventory(){
      const list=$('#moduleList'); let html='';
      GROUPS.filter(g=>inventoryFilter==='all'||inventoryFilter===g.id).forEach(g=>{
        const items=MODULES.filter(m=>m.group===g.id);
        html+=`<div class="inventory-group" style="color:${g.color}">${g.name}</div>`;
        html+=items.map(m=>`<div class="inventory-row ${selectedId===m.id?'selected':''}" data-id="${m.id}" draggable="true" style="--accent:${g.color}"><span class="inventory-id">${m.id}</span><span class="inventory-name">${safe(m.title)}</span></div>`).join('');
      });
      list.innerHTML=html;
      list.querySelectorAll('.inventory-row').forEach(row=>{
        row.addEventListener('click',()=>select(row.dataset.id));
        row.addEventListener('dragstart',e=>{draggedId=row.dataset.id;e.dataTransfer.setData('text/plain',draggedId);e.dataTransfer.effectAllowed='move';});
        row.addEventListener('dragend',()=>{draggedId=null;$('#flowCanvas').classList.remove('drag-over');hideInsertLine();});
      });
    }
    function parseKnob(v){const [a,...b]=v.split('=');return {key:a,value:b.join('=')||'required'}}
    function renderInspector(m){
      if(!m){$('#inspectorContent').innerHTML='<div class="empty-state">Kliknij klocek lub wybierz go z inventory.<br><br>Canvas pokazuje identyfikator, nazwę i mini-wizualizację warstwy. Inspector pokazuje kontrakt procedury: input → transform → output → invariants → knobs.</div>';return;}
      const c=color(m);
      /* zachowaj stan akordeonu i scroll promptu przez re-render (toggle, nowy kabel) */
      const prevAcc=$('#inspectorContent .prompt-acc');
      const accOpen=!!(prevAcc&&prevAcc.open);
      const preScroll=accOpen?(($('#inspectorContent .prompt-pre')||{}).scrollTop||0):0;
      $('#inspectorContent').innerHTML=`
        <div class="selected-strip"><div class="selected-id" style="background:${c}">${m.id}</div><div><div class="selected-name">${safe(m.title)}</div><div class="selected-kind">${safe(m.kind)} — ${safe(m.short)}</div></div></div>
        ${isCustom(m.id)?`<div class="del-wrap"><button class="del-block" id="delBlock">USUŃ KLOCEK</button></div>`:''}
        <section class="inspect-section"><div class="inspect-label">INPUT</div><ul class="inspect-list">${m.input.map(x=>`<li>${safe(x)}</li>`).join('')}</ul></section>
        <section class="inspect-section"><div class="inspect-label">TRANSFORM</div><ul class="inspect-list">${m.transform.map(x=>`<li>${safe(x)}</li>`).join('')}</ul></section>
        <section class="inspect-section"><div class="inspect-label">OUTPUT</div><div class="inspect-text">${safe(m.output)}</div></section>
        <section class="inspect-section"><div class="inspect-label">INVARIANTS</div><ul class="inspect-list">${m.invariant.map(x=>`<li>${safe(x)}</li>`).join('')}</ul></section>
        <section class="inspect-section"><div class="inspect-label">LOW-CODE KNOBS</div><div class="knob-grid">${m.knobs.map(x=>{const k=parseKnob(x);return `<div class="knob"><b>${safe(k.key)}</b><span>${safe(k.value)}</span></div>`}).join('')}</div></section>
        <section class="inspect-section"><div class="inspect-label">VISUALIZATION</div><div class="viz-card" style="--accent:${c}">${vizCard(m)}</div></section>
        <section class="inspect-section"><details class="prompt-acc"${accOpen?' open':''}><summary><i>▸</i> PROMPT REPLIKACYJNY · DECYZJE &amp; BEST PRACTICES</summary><div class="prompt-bar"><button id="copyReplica">KOPIUJ PROMPT</button></div><pre class="prompt-pre">${safe(replicationPrompt(m))}</pre></details></section>`;
      if(accOpen){const pp=$('#inspectorContent .prompt-pre');if(pp)pp.scrollTop=preScroll;}
      $('#copyReplica').onclick=()=>copyText(replicationPrompt(m));
      if(isCustom(m.id)){const db=$('#delBlock');if(db)db.onclick=()=>deleteCustomBlock(m.id);}
      const sid=$('#inspectorContent .selected-id');        // klik w badge ID → edycja (custom) / toast (wbudowany)
      if(sid){if(isCustom(m.id)){sid.style.cursor='pointer';sid.title='Edytuj klocek';sid.onclick=()=>openEditModal(m.id);}
        else{sid.style.cursor='help';sid.title='Wbudowany klocek — edytuj w źródle (SOT)';sid.onclick=()=>toast('Wbudowany klocek — edytuj w źródle (SOT)');}}
    }
    /* prompt replikacyjny: sekcja KONTEKST liczona statycznie z
       MODULES[].depends (depsOf / dependentsOf), więc zawsze opisuje
       zadeklarowaną okoliczną logikę; treść merytoryczna z
       PROMPTS[id] — patrz sekcja [J1b] */
    function replicationPrompt(m){
      const P=PROMPTS[m.id]||{};
      const up=depsOf(m.id).map(d=>{const dm=mod(d);return dm?`upstream: ${d} „${dm.title}" → dostarcza: ${dm.output}`:`upstream: ${d}`;});
      const down=dependentsOf(m.id).map(d=>{const dm=mod(d);return dm?`downstream: ${m.output} → konsumuje: ${d} „${dm.title}"`:`downstream: ${d}`;});
      const ctx=[...(up.length?up:['upstream: brak — pierwszy klocek przepływu']),
                 ...(down.length?down:['downstream: brak — ostatni klocek przepływu']),
                 'model wykonania: per-asset one-shot notebook L4→L9 (make run-asset), uniwersum = make loop; brak faz globalnych'];
      const sec=(h,items)=>`\n\n${h}\n`+items.map(x=>'- '+x).join('\n');
      return `=== ${m.id} · ${m.title} — PROMPT REPLIKACYJNY ===`+
        sec('CEL',[P.cel||m.kind])+
        sec('KONTEKST PIPELINE (okoliczna logika)',ctx)+
        sec('DECYZJE PROJEKTOWE',P.decyzje||[])+
        sec('INWARIANTY (nienegocjowalne)',P.inwarianty||m.invariant)+
        sec('KNOBS (parametry low-code)',m.knobs)+
        sec('TESTY AKCEPTACYJNE',P.testy||m.test)+
        sec('ZASADY IMPLEMENTACJI',[...(P.zasady||[]),...PROMPT_FOOTER]);
    }
    function toast(msg){const el=$('#toast');el.textContent=msg;el.classList.add('show');clearTimeout(toast.t);toast.t=setTimeout(()=>el.classList.remove('show'),1500)}
    async function copyText(t){try{await navigator.clipboard.writeText(t);toast('COPIED');}catch(e){toast('CLIPBOARD UNAVAILABLE');}}

    /* ==================================================================
       [J9] MODAL + CUSTOM — okno „+" (dodaj klocek, F1), okno potwierdzenia
       przeniesienia (F2) oraz custom-moduły trzymane w localStorage v2.custom.
       Wszystkie treści użytkownika przechodzą przez safe(); id ograniczone do
       [A-Za-z0-9._-] (lego()/renderInventory wstrzykują ${m.id} RAW).
       ================================================================== */
    function recomputeCanvasH(){CANVAS_H=TOP_PAD+BOTTOM_PAD+MODULES.reduce((a,m)=>a+VIZ[m.viz].h+GAP,0)-GAP;return CANVAS_H;}
    function sizeCanvas(){const fc=$('#flowCanvas');if(fc){fc.style.width=CANVAS_W+'px';fc.style.height=CANVAS_H+'px';}}

    const ID_RE=/^[A-Za-z0-9._-]{1,24}$/;
    function isCustom(id){const m=mod(id);return !!(m&&m._custom);}
    function normalizeModule(raw){
      if(!raw||typeof raw!=='object')return null;
      const id=String(raw.id||'').trim();
      if(!ID_RE.test(id))return null;
      if(!VIZ[raw.viz])return null;                          // zła viz → drop (nie crashuj VIZ[m.viz].h)
      if(!GROUPS.some(g=>g.id===raw.group))return null;
      const title=String(raw.title||'').trim();if(!title)return null;
      const arr=v=>Array.isArray(v)?v.map(x=>String(x)).filter(Boolean):[];
      return {id,group:raw.group,viz:raw.viz,title,
        kind:String(raw.kind||'custom module'),short:String(raw.short||''),
        input:arr(raw.input),transform:arr(raw.transform),output:String(raw.output||'—'),
        invariant:arr(raw.invariant),knobs:arr(raw.knobs),test:arr(raw.test),depends:arr(raw.depends),
        _custom:true};
    }
    function loadCustomModules(){                            // BOOT: PRZED pierwszym getState()
      let raw=null;try{raw=JSON.parse(localStorage.getItem(STORAGE));}catch(e){}
      const list=(raw&&Array.isArray(raw.custom))?raw.custom:[];
      list.forEach(r=>{const m=normalizeModule(r);if(m&&!MODULES.some(x=>x.id===m.id))MODULES.push(m);});
    }
    function deleteCustomBlock(id){
      if(!isCustom(id))return;
      const i=MODULES.findIndex(m=>m.id===id);if(i>=0)MODULES.splice(i,1);
      const s=getState();
      s.order=s.order.filter(x=>x!==id);
      s.custom=MODULES.filter(m=>m._custom);
      saveState(s);
      if(selectedId===id)selectedId=null;
      recomputeCanvasH();sizeCanvas();
      renderInventory();renderCanvas();renderInspector(selectedId?mod(selectedId):null);
      toast(id+' USUNIĘTY');
    }

    /* ---- generyczna powłoka modala (F1 + F2) ---- */
    let modalMode=null,pendingMove=null,editId=null;
    function openModal(title,bodyHTML,buttons,onShow){
      $('#modalTitle').innerHTML=title;
      $('#modalBody').innerHTML=bodyHTML;
      const foot=$('#modalFoot');foot.innerHTML='';
      buttons.forEach(b=>{const el=document.createElement('button');
        el.className='modal-btn'+(b.variant?' '+b.variant:'');el.textContent=b.label;el.onclick=b.onClick;foot.appendChild(el);});
      $('#modalOverlay').hidden=false;
      document.removeEventListener('keydown',modalKeydown);   // idempotentnie, bez leaka
      document.addEventListener('keydown',modalKeydown);
      if(onShow)onShow();
    }
    function closeModal(){$('#modalOverlay').hidden=true;document.removeEventListener('keydown',modalKeydown);modalMode=null;pendingMove=null;editId=null;}
    function modalKeydown(e){
      if(e.key==='Escape'){e.preventDefault();closeModal();}
      else if(e.key==='Enter'&&modalMode==='move'){e.preventDefault();commitMove();}
      else if(e.key==='Enter'&&e.target.tagName!=='TEXTAREA'&&modalMode==='add'){e.preventDefault();submitAddBlock();}
      else if(e.key==='Enter'&&e.target.tagName!=='TEXTAREA'&&modalMode==='edit'){e.preventDefault();submitEditBlock(editId);}
    }
    function focusFirst(){const el=$('#modalBody').querySelector('select,input,textarea')||$('#modalFoot').querySelector('.modal-btn.primary')||$('#modalFoot').querySelector('.modal-btn');if(el)el.focus();}

    /* ---- F1: dodaj / edytuj klocek (wspólny formularz) ---- */
    function suggestId(groupId){const pre=groupId==='sg'?'G':groupId.replace('s','');let n=1,id;do{id=pre+'.C'+n;n++;}while(MODULES.some(m=>m.id===id));return id;}
    function fieldWrap(fid,label,control){return `<div class="modal-field" id="fld-${fid}"><label for="f-${fid}">${label}</label>${control}<span class="err-msg"></span></div>`;}
    /* p=preset (edit) lub {} (add). p._edit → ID readonly (id = klucz, niezmienny). */
    function blockFormBody(p){
      p=p||{};const v=x=>safe(x==null?'':String(x));const lines=a=>safe(Array.isArray(a)?a.join('\n'):'');
      const sel=(cur,val)=>cur===val?' selected':'';
      const gopts=GROUPS.map(g=>`<option value="${g.id}"${sel(p.group,g.id)}>${safe(g.name)}</option>`).join('');
      const vopts=Object.keys(VIZ).map(k=>`<option value="${k}"${sel(p.viz||'guard',k)}>${k}</option>`).join('');
      const ta=(fid,ph,val)=>`<textarea id="f-${fid}" placeholder="${ph}">${val||''}</textarea>`;
      const idVal=v(p.id!=null?p.id:suggestId(GROUPS[0].id));
      return `
        <div class="modal-grid2">
          ${fieldWrap('group','Tor',`<select id="f-group">${gopts}</select>`)}
          ${fieldWrap('id','ID',`<input id="f-id" value="${idVal}" maxlength="24"${p._edit?' readonly':''}>`)}
        </div>
        ${fieldWrap('title','Tytuł',`<input id="f-title" value="${v(p.title)}" placeholder="np. custom quality gate">`)}
        ${fieldWrap('kind','Rodzaj',`<input id="f-kind" value="${v(p.kind)}" placeholder="np. fail-closed gate">`)}
        ${fieldWrap('short','Krótki opis',`<input id="f-short" value="${v(p.short)}" placeholder="input → output w 1 linii">`)}
        <div class="modal-grid2">
          ${fieldWrap('viz','Viz',`<select id="f-viz">${vopts}</select>`)}
          ${fieldWrap('depends','Zależności (id, po przecinku)',`<input id="f-depends" value="${safe((p.depends||[]).join(', '))}" placeholder="1.4, G.1">`)}
        </div>
        ${fieldWrap('input','INPUT (1 pozycja / linia)',ta('input','1 wejście / linia',lines(p.input)))}
        ${fieldWrap('transform','TRANSFORM (1 pozycja / linia)',ta('transform','1 krok / linia',lines(p.transform)))}
        ${fieldWrap('output','OUTPUT (1 linia)',`<input id="f-output" value="${v(p.output&&p.output!=='—'?p.output:'')}" placeholder="artefakt wyjściowy">`)}
        ${fieldWrap('invariant','INVARIANTS (1 pozycja / linia)',ta('invariant','1 inwariant / linia',lines(p.invariant)))}
        ${fieldWrap('knobs','KNOBS (key=value / linia)',ta('knobs','key=value / linia',lines(p.knobs)))}
        ${fieldWrap('test','TESTS (1 pozycja / linia)',ta('test','1 test / linia',lines(p.test)))}`;
    }
    function readBlockForm(){
      const val=id=>(($('#'+id)||{}).value||'');
      const lines=fid=>val(fid).split('\n').map(s=>s.trim()).filter(Boolean);
      return {id:val('f-id').trim(),group:val('f-group'),title:val('f-title').trim(),viz:val('f-viz'),
        kind:val('f-kind').trim(),short:val('f-short').trim(),
        depends:val('f-depends').split(',').map(s=>s.trim()).filter(Boolean),
        input:lines('f-input'),transform:lines('f-transform'),output:val('f-output').trim()||'—',
        invariant:lines('f-invariant'),knobs:lines('f-knobs'),test:lines('f-test')};
    }
    function markErr(fid,msg){const f=$('#fld-'+fid);if(!f)return null;f.classList.add('err');const e=f.querySelector('.err-msg');if(e)e.textContent=msg;return fid;}
    function focusFirstErr(){const f=$('#modalBody .modal-field.err input,#modalBody .modal-field.err select');if(f)f.focus();}
    function openAddModal(){
      modalMode='add';
      openModal('DODAJ KLOCEK',blockFormBody(),[
        {label:'ANULUJ',onClick:closeModal},
        {label:'OK',variant:'primary',onClick:submitAddBlock}
      ],()=>{
        focusFirst();
        const gsel=$('#f-group'),idin=$('#f-id');let last=idin.value,touched=false;
        idin.addEventListener('input',()=>{touched=(idin.value!==last);});
        gsel.addEventListener('change',()=>{if(!touched){last=suggestId(gsel.value);idin.value=last;}});
      });
    }
    function submitAddBlock(){
      document.querySelectorAll('#modalBody .modal-field').forEach(f=>f.classList.remove('err'));
      const d=readBlockForm();let bad=null;
      if(!ID_RE.test(d.id))bad=bad||markErr('id','ID: 1–24 znaków [A-Za-z0-9._-]');
      else if(MODULES.some(m=>m.id===d.id))bad=bad||markErr('id','ID musi być unikalne');
      if(!d.title)bad=bad||markErr('title','Tytuł wymagany');
      if(!VIZ[d.viz])bad=bad||markErr('viz','Nieznany viz');
      if(bad){focusFirstErr();return;}
      const m=normalizeModule(d);
      if(!m){toast('Niepoprawny moduł');return;}
      MODULES.push(m);
      const s=getState();
      s.order.push(m.id);                                     // szczyt drabinki = koniec order
      s.custom=MODULES.filter(x=>x._custom);
      saveState(s);                                           // _state spójny (memoizacja)
      recomputeCanvasH();sizeCanvas();
      selectedId=m.id;
      renderInventory();renderCanvas();renderInspector(m);fitView();
      closeModal();toast(d.id+' DODANY');
    }
    function openEditModal(id){
      const m=mod(id);if(!m||!isCustom(id))return;           // edycja tylko dla custom
      modalMode='edit';editId=id;
      openModal('EDYTUJ KLOCEK · '+safe(id),blockFormBody({...m,_edit:true}),[
        {label:'ANULUJ',onClick:closeModal},
        {label:'ZAPISZ',variant:'primary',onClick:()=>submitEditBlock(id)}
      ],focusFirst);
    }
    function submitEditBlock(id){
      if(!id||!isCustom(id))return;
      document.querySelectorAll('#modalBody .modal-field').forEach(f=>f.classList.remove('err'));
      const d=readBlockForm();d.id=id;                       // ID niezmienne (readonly)
      let bad=null;
      if(!d.title)bad=bad||markErr('title','Tytuł wymagany');
      if(!VIZ[d.viz])bad=bad||markErr('viz','Nieznany viz');
      if(bad){focusFirstErr();return;}
      const m=normalizeModule(d);
      if(!m){toast('Niepoprawny moduł');return;}
      const i=MODULES.findIndex(x=>x.id===id);if(i<0)return;
      MODULES[i]=m;                                           // podmiana w miejscu (zachowuje pozycję + _custom)
      const s=getState();s.custom=MODULES.filter(x=>x._custom);saveState(s);
      recomputeCanvasH();sizeCanvas();                        // viz/wysokość mogła się zmienić
      renderInventory();renderCanvas();renderInspector(m);
      closeModal();toast(id+' ZAPISANY');
    }

    /* ---- F2: potwierdzenie przeniesienia ---- */
    function describeMove(id,newOrder){
      const m=mod(id),i=newOrder.indexOf(id);
      const below=i>0?mod(newOrder[i-1]):null;                // order[i-1] = fizycznie NIŻEJ (drabinka dół→góra)
      const above=i<newOrder.length-1?mod(newOrder[i+1]):null;
      const where=!below?'na dół drabinki':!above?'na szczyt drabinki':`między <b>${safe(below.id)}</b> a <b>${safe(above.id)}</b>`;
      const line=(lab,x)=>`${lab}: `+(x?`<b>${safe(x.id)}</b> „${safe(x.title)}"`:'—');
      return `<div class="move-summary">Przenieś <span class="move-chip">${safe(id)} · ${safe(m.title)}</span><br>pozycja docelowa: <b>${where}</b><br>${line('poniżej',below)}<br>${line('powyżej',above)}</div>`;
    }
    function openMoveModal(proposed){
      modalMode='move';pendingMove=proposed;
      openModal('POTWIERDŹ PRZENIESIENIE',proposed.summaryHTML,[
        {label:'ANULUJ',onClick:closeModal},
        {label:'OK',variant:'primary',onClick:commitMove}
      ],focusFirst);
    }
    function commitMove(){
      if(!pendingMove)return;
      const {id,newOrder}=pendingMove;
      const s=getState();s.order=newOrder;saveState(s);
      selectedId=id;closeModal();
      document.querySelectorAll('#flowCanvas .lego').forEach(el=>el.classList.toggle('selected',el.dataset.id===id));
      repositionBlocks();renderInventory();renderInspector(mod(id));   // repositionBlocks = animowany slide
    }

    /* ==================================================================
       [J8] BOOT
       ================================================================== */
    loadCustomModules();            // 1. PRZED pierwszym getState()/renderem — customy trafiają do MODULES
    recomputeCanvasH();sizeCanvas();// 2-3. wysokość obejmuje customy (zamiast inline width/height)
    renderLaneSeps();renderLaneHeads();
    renderFilters();renderInventory();renderCanvas();renderInspector(null);
    fitView();
    $('#addFab').onclick=openAddModal;
    $('#modalOverlay').addEventListener('click',e=>{if(e.target===$('#modalOverlay'))closeModal();}); // backdrop = cancel
  </script>
</body>
</html>
