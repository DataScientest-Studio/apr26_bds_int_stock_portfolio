          'G.3':[['accept','correctness_check · PF rankable'],['threshold','{{THRESHOLD_ENTRY}} fixed · never OOS-tuned'],['files','exactly 7 · SystemExit'],['selfcheck','golden vectors · hash bind']]};
        const rows=(R[m.id]||[['guard','checks defined per module']]).map(([k,t])=>`<div class="qc-row"><b>${k}</b><span>${t}</span><span class="qc-ok">✓</span></div>`).join('');
