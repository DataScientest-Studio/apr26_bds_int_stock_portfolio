      /* G.x — generic guard: kompaktowa checklista bramki (fail-closed);
         nowy guard: dopisz wiersze do R[id] albo polegaj na fallbacku */
      guard:{h:104,render:m=>{
        const R={
          'G.1':[['time','parse · unique · monotonic'],['ohlc','finite · &gt;0 · hi/lo bounds'],['volume','finite · ≥ 0'],['verdict','RuntimeError · never cleaned']],
